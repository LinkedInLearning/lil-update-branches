{
  "name": "lil-update-branches",
  "version": "1.0.0",
  "description": "GitHub Action that copies selected files from one branch to all other branches.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && npm run package",
    "package": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "all": "npm run lint && tsc --noEmit && npm test && npm run package"
  },
  "keywords": ["github", "action", "branches", "sync"],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "minimatch": "^9.0.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  }
}
