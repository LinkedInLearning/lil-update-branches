{
  "name": "lil-update-branches",
  "version": "1.0.0",
  "description": "GitHub Action that copies selected files from one branch to all other branches.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && npm run package",
    "package": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "lint": "eslint .",
    "test": "jest",
    "all": "npm run lint && tsc --noEmit && npm test && npm run package"
  },
  "keywords": ["github", "action", "branches", "sync"],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "minimatch": "^10.2.5"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@vercel/ncc": "^0.44.0",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
